<Page x:Class="Econova.PaginaVerClientes"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="White">

    <Page.Resources>
        <SolidColorBrush x:Key="AccentBrush"  Color="#2563EB"/>
        <SolidColorBrush x:Key="BorderColor"  Color="#E5E7EB"/>

        <Style x:Key="ColHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontFamily"        Value="Segoe UI"/>
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="FontWeight"        Value="SemiBold"/>
            <Setter Property="Foreground"        Value="#6B7280"/>
            <Setter Property="Padding"           Value="12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CellStyle" TargetType="TextBlock">
            <Setter Property="FontFamily"        Value="Segoe UI"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="Foreground"        Value="#000000"/>
            <Setter Property="Padding"           Value="12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming"      Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnEditarStyle" TargetType="Button"
               BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background"  Value="#FFFBEB"/>
            <Setter Property="BorderBrush" Value="#FDE68A"/>
            <Setter Property="Foreground"  Value="#92400E"/>
        </Style>

        <Style x:Key="BtnEliminarStyle" TargetType="Button"
               BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background"  Value="#FEF2F2"/>
            <Setter Property="BorderBrush" Value="#FECACA"/>
            <Setter Property="Foreground"  Value="#DC2626"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══════ ENCABEZADO ══════ -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,0,1"
                Padding="28,16,28,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="40" Height="40" CornerRadius="10"
                            Background="#F0FDF4" Margin="0,0,14,0">
                        <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="20" Foreground="#059669"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Clientes"
                                   FontFamily="Segoe UI" FontSize="18"
                                   FontWeight="Bold" Foreground="#000000"/>
                        <TextBlock x:Name="TxtSubtitulo"
                                   Text="Todos los clientes registrados"
                                   FontFamily="Segoe UI" FontSize="12"
                                   Foreground="#6B7280" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Botón nuevo cliente -->
                <Button Grid.Column="1"
                        Height="36" Padding="16,0"
                        Background="#2563EB" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnNuevoCliente_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#1D4ED8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal" Margin="4,0">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="13" Margin="0,0,8,0"
                                   VerticalAlignment="Center" Foreground="White"/>
                        <TextBlock Text="Nuevo cliente" FontFamily="Segoe UI"
                                   FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Foreground="White"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ══════ BARRA DE BÚSQUEDA ══════ -->
        <Border Grid.Row="1" Background="#F9FAFB"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,0,1"
                Padding="28,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Background="White" BorderBrush="#9CA3AF"
                        BorderThickness="1" CornerRadius="8"
                        Width="380" HorizontalAlignment="Left">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="13" Foreground="#9CA3AF"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtBuscar"
                                 Grid.Column="1"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontFamily="Segoe UI" FontSize="13"
                                 Foreground="#000000"
                                 Height="36" Width="344"
                                 HorizontalAlignment="Left"
                                 VerticalContentAlignment="Center"
                                 TextChanged="TxtBuscar_TextChanged"/>
                    </Grid>
                </Border>

                <TextBlock x:Name="TxtContador"
                           Grid.Column="1"
                           FontFamily="Segoe UI" FontSize="13"
                           Foreground="#6B7280"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ══════ TABLA DE CLIENTES ══════ -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="28,16,28,24">

                <!-- Encabezado tabla -->
                <Border Background="#F9FAFB"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1" CornerRadius="8,8,0,0"
                        Height="40">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="#"
                                   Style="{StaticResource ColHeaderStyle}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Nombre completo"
                                   Style="{StaticResource ColHeaderStyle}"/>
                        <TextBlock Grid.Column="2" Text="Cédula"
                                   Style="{StaticResource ColHeaderStyle}"/>
                        <TextBlock Grid.Column="3" Text="Correo"
                                   Style="{StaticResource ColHeaderStyle}"/>
                        <TextBlock Grid.Column="4" Text="Teléfono"
                                   Style="{StaticResource ColHeaderStyle}"/>
                        <TextBlock Grid.Column="5" Text="Acciones"
                                   Style="{StaticResource ColHeaderStyle}"
                                   HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Filas -->
                <ItemsControl x:Name="ListaClientes">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource BorderColor}"
                                    BorderThickness="1,0,1,1"
                                    Height="52" Background="White">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#F9FAFB"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="160"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Numero}"
                                               Style="{StaticResource CellStyle}"
                                               Foreground="#9CA3AF"
                                               HorizontalAlignment="Center"/>

                                    <!-- Avatar + Nombre -->
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                Margin="12,0,0,0">
                                        <Border Width="32" Height="32"
                                                CornerRadius="16"
                                                Background="#DBEAFE"
                                                Margin="0,0,10,0">
                                            <TextBlock Text="{Binding Inicial}"
                                                       FontFamily="Segoe UI"
                                                       FontSize="13"
                                                       FontWeight="Bold"
                                                       Foreground="#1D4ED8"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding NombreCompleto}"
                                                       FontFamily="Segoe UI"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="#000000"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Cedula}"
                                               Style="{StaticResource CellStyle}"
                                               Foreground="#6B7280"/>
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding Email}"
                                               Style="{StaticResource CellStyle}"
                                               Foreground="#6B7280"/>
                                    <TextBlock Grid.Column="4"
                                               Text="{Binding Telefono}"
                                               Style="{StaticResource CellStyle}"/>

                                    <!-- Acciones -->
                                    <StackPanel Grid.Column="5"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <Button Style="{StaticResource BtnEditarStyle}"
                                                Margin="0,0,8,0"
                                                Tag="{Binding Id}"
                                                Click="BtnEditar_Click">
                                            <StackPanel Orientation="Horizontal" Margin="4,0">
                                                <TextBlock Text="&#xE70F;"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="11" Margin="0,0,6,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="Editar"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource BtnEliminarStyle}"
                                                Tag="{Binding Id}"
                                                Click="BtnEliminar_Click">
                                            <StackPanel Orientation="Horizontal" Margin="4,0">
                                                <TextBlock Text="&#xE74D;"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="11" Margin="0,0,6,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="Eliminar"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Pie de tabla -->
                <Border Background="#F9FAFB"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1,0,1,1"
                        CornerRadius="0,0,8,8"
                        Height="12"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>