<Page x:Class="Econova.Views.Pages.PaginaCrearReserva"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:Econova.ViewModels"
      Background="White">

    <Page.Resources>
        <SolidColorBrush x:Key="AccentBrush"   Color="#2563EB"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#000000"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#000000"/>
        <SolidColorBrush x:Key="BorderColor"   Color="#D1D5DB"/>
        <SolidColorBrush x:Key="InputBg"       Color="#F9FAFB"/>

        <!-- Etiqueta de campo -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
        </Style>

        <!-- Estilo base compartido para inputs y combos -->
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="FontFamily"               Value="Segoe UI"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="Foreground"               Value="#000000"/>
            <Setter Property="Background"               Value="{StaticResource InputBg}"/>
            <Setter Property="BorderBrush"              Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Padding"                  Value="10,0"/>
            <Setter Property="Height"                   Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush"
                                        Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox -->
        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Foreground"      Value="#000000"/>
            <Setter Property="Background"      Value="{StaticResource InputBg}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="38"/>
            <Setter Property="Padding"         Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="7">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="32"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter x:Name="ContentSite"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      Margin="10,0,0,0"
                                                      VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="&#xE70D;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="10"
                                               Foreground="#6B7280"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <ToggleButton Opacity="0"
                                          IsChecked="{Binding IsDropDownOpen,
                                          RelativeSource={RelativeSource TemplatedParent},
                                          Mode=TwoWay}"/>
                            <Popup x:Name="Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide"
                                   Placement="Bottom">
                                <Border Background="White"
                                        BorderBrush="{StaticResource BorderColor}"
                                        BorderThickness="1"
                                        CornerRadius="7"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000" BlurRadius="12"
                                                          ShadowDepth="2" Opacity="0.08"/>
                                    </Border.Effect>
                                    <ScrollViewer MaxHeight="200" Padding="4">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush"
                                        Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="FontFamily" Value="Segoe UI"/>
                    <Setter Property="FontSize"   Value="13"/>
                    <Setter Property="Foreground" Value="#000000"/>
                    <Setter Property="Padding"    Value="10,8"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="itemBorder"
                                        Background="Transparent"
                                        CornerRadius="5"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="itemBorder" Property="Background" Value="#EEF2FF"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="itemBorder" Property="Background" Value="#DBEAFE"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Style.Resources>
        </Style>

        <!-- Botón AM/PM -->
        <Style x:Key="AmPmButtonStyle" TargetType="Button">
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Foreground"      Value="#000000"/>
            <Setter Property="Background"      Value="{StaticResource InputBg}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width"           Value="56"/>
            <Setter Property="Height"          Value="38"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EEF2FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón AM/PM activo -->
        <Style x:Key="AmPmButtonActiveStyle" TargetType="Button"
               BasedOn="{StaticResource AmPmButtonStyle}">
            <Setter Property="Background"   Value="#2563EB"/>
            <Setter Property="BorderBrush"  Value="#2563EB"/>
            <Setter Property="Foreground"   Value="White"/>
        </Style>

        <!-- Botón confirmar -->
        <Style x:Key="ConfirmButtonStyle" TargetType="Button">
            <Setter Property="Height"          Value="44"/>
            <Setter Property="Background"      Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1E40AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón buscar cédula -->
        <Style x:Key="SearchButtonStyle" TargetType="Button">
            <Setter Property="Width"           Value="38"/>
            <Setter Property="Height"          Value="38"/>
            <Setter Property="Background"      Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontFamily"      Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DatePicker con template personalizado -->
        <Style x:Key="DateStyle" TargetType="DatePicker">
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Foreground"      Value="#000000"/>
            <Setter Property="Height"          Value="38"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background"      Value="{StaticResource InputBg}"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border x:Name="border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="7">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="38"/>
                                </Grid.ColumnDefinitions>

                                <!-- Campo de texto de la fecha -->
                                <DatePickerTextBox x:Name="PART_TextBox"
                                           Grid.Column="0"
                                           Foreground="#000000"
                                           Background="Transparent"
                                           BorderThickness="0"
                                           FontFamily="Segoe UI"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           Padding="10,0,0,0"/>

                                <!-- Botón del calendario -->
                                <Button x:Name="PART_Button"
                                Grid.Column="1"
                                Background="Transparent"
                                BorderThickness="0"
                                Width="38" Height="38"
                                Cursor="Hand"
                                Focusable="False">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="btnBorder"
                                            Background="Transparent"
                                            CornerRadius="0,7,7,0">
                                                <TextBlock Text="&#xE787;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="16"
                                                   Foreground="#2563EB"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="btnBorder"
                                                    Property="Background" Value="#EEF2FF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- Popup del calendario -->
                                <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               Placement="Bottom"
                               StaysOpen="False"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush"
                                Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,24,28,24">

            <!-- Encabezado -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <Border Width="40" Height="40" CornerRadius="10"
                        Background="#EFF6FF" Margin="0,0,14,0">
                    <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets"
                               FontSize="20" Foreground="#2563EB"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Crear reserva"
                               FontFamily="Segoe UI" FontSize="18" FontWeight="Bold"
                               Foreground="#000000"/>
                    <TextBlock Text="Completa los datos para registrar una nueva reserva."
                               FontFamily="Segoe UI" FontSize="12"
                               Foreground="#000000" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Tarjeta formulario -->
            <Border Background="White" BorderBrush="#E5E7EB"
                    BorderThickness="1" CornerRadius="12" Padding="24">
                <Border.Effect>
                    <DropShadowEffect Color="#000" BlurRadius="16"
                                      ShadowDepth="2" Opacity="0.06"/>
                </Border.Effect>
                <StackPanel>

                    <!-- Sala -->
                    <TextBlock Text="Sala" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="CmbSala"
                              Style="{StaticResource ComboStyle}"
                              Margin="0,0,0,20">
                        <ComboBoxItem Content="Sala 1 — Capacidad 10 personas"/>
                        <ComboBoxItem Content="Sala 2 — Capacidad 20 personas"/>
                        <ComboBoxItem Content="Sala 3 — Capacidad 30 personas"/>
                        <ComboBoxItem Content="Sala 4 — Capacidad 50 personas"/>
                        <ComboBoxItem Content="Salón principal — Capacidad 100 personas"/>
                    </ComboBox>

                    <!-- Fecha y hora de entrada -->
                    <TextBlock Text="Fecha y hora de entrada"
                               Style="{StaticResource FieldLabel}"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <!-- Fecha -->
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <!-- Hora -->
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="6"/>
                            <!-- Separador : -->
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="6"/>
                            <!-- Minutos -->
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="6"/>
                            <!-- AM/PM -->
                            <ColumnDefinition Width="56"/>
                        </Grid.ColumnDefinitions>

                        <DatePicker x:Name="DpFechaEntrada"
                                    Grid.Column="0"
                                    Style="{StaticResource DateStyle}"/>

                        <TextBox x:Name="TxtHoraEntrada"
                                 Grid.Column="2"
                                 Style="{StaticResource InputStyle}"
                                 Text="08"
                                 MaxLength="2"
                                 TextAlignment="Center"
                                 ToolTip="Hora (01-12)"
                                 PreviewTextInput="SoloNumeros_PreviewTextInput"/>

                        <TextBlock Grid.Column="4"
                                   Text=":"
                                   FontFamily="Segoe UI" FontSize="18"
                                   FontWeight="Bold" Foreground="#000000"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                        <TextBox x:Name="TxtMinEntrada"
                                 Grid.Column="6"
                                 Style="{StaticResource InputStyle}"
                                 Text="00"
                                 MaxLength="2"
                                 TextAlignment="Center"
                                 ToolTip="Minutos (00-59)"
                                 PreviewTextInput="SoloNumeros_PreviewTextInput"/>

                        <Button x:Name="BtnAmPmEntrada"
                                Grid.Column="8"
                                Style="{StaticResource AmPmButtonActiveStyle}"
                                Content="AM"
                                Click="BtnAmPmEntrada_Click"/>
                    </Grid>

                    <!-- Fecha y hora de salida -->
                    <TextBlock Text="Fecha y hora de salida"
                               Style="{StaticResource FieldLabel}"/>
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="56"/>
                        </Grid.ColumnDefinitions>

                        <DatePicker x:Name="DpFechaSalida"
                                    Grid.Column="0"
                                    Style="{StaticResource DateStyle}"/>

                        <TextBox x:Name="TxtHoraSalida"
                                 Grid.Column="2"
                                 Style="{StaticResource InputStyle}"
                                 Text="05"
                                 MaxLength="2"
                                 TextAlignment="Center"
                                 ToolTip="Hora (01-12)"
                                 PreviewTextInput="SoloNumeros_PreviewTextInput"/>

                        <TextBlock Grid.Column="4"
                                   Text=":"
                                   FontFamily="Segoe UI" FontSize="18"
                                   FontWeight="Bold" Foreground="#000000"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                        <TextBox x:Name="TxtMinSalida"
                                 Grid.Column="6"
                                 Style="{StaticResource InputStyle}"
                                 Text="00"
                                 MaxLength="2"
                                 TextAlignment="Center"
                                 ToolTip="Minutos (00-59)"
                                 PreviewTextInput="SoloNumeros_PreviewTextInput"/>

                        <Button x:Name="BtnAmPmSalida"
                                Grid.Column="8"
                                Style="{StaticResource AmPmButtonStyle}"
                                Content="PM"
                                Click="BtnAmPmSalida_Click"/>
                    </Grid>

                    <!-- Separador -->
                    <Rectangle Height="1" Fill="#E5E7EB" Margin="0,0,0,24"/>

                    <!-- Buscar cliente -->
                    <TextBlock Text="Cliente" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="Ingresa la cédula para buscar el cliente."
                               FontFamily="Segoe UI" FontSize="12"
                               Foreground="#000000" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtCedula"
                                 Grid.Column="0"
                                 Text="{Binding Cedula, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputStyle}"
                                 ToolTip="Ej: 1234567890"
                                 MaxLength="10"
                                 PreviewTextInput="SoloNumeros_PreviewTextInput"/>
                        <Button Grid.Column="2"
                                Style="{StaticResource SearchButtonStyle}"
                                Content="&#xE721;"
                                ToolTip="Buscar cliente"
                                Command="{Binding BuscarClienteCommand}"/>
                    </Grid>

                    <!-- Panel resultado cliente -->
                    <Border x:Name="PanelCliente"
                            Visibility="{Binding PanelClienteVisibility}"
                            Background="#F0FDF4"
                            BorderBrush="#BBF7D0"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14,10"
                            Margin="0,0,0,24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" CornerRadius="18"
                                    Background="#DCFCE7" Margin="0,0,12,0">
                                <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" Foreground="#16A34A"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="TxtNombreCliente"
                                           Text="{Binding NombreCliente}"
                                           FontFamily="Segoe UI" FontSize="13"
                                           FontWeight="SemiBold" Foreground="#15803D"/>
                                <TextBlock x:Name="TxtInfoCliente"
                                           Text="{Binding InfoCliente}"
                                           FontFamily="Segoe UI" FontSize="12"
                                           Foreground="#16A34A"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Botón confirmar -->
                    <Button Content="Confirmar Reserva"
                            Style="{StaticResource ConfirmButtonStyle}"
                            Command="{Binding ConfirmarReservaCommand}"/>

                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>