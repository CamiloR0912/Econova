<Page x:Class="Econova.Views.Pages.PaginaVerReservas"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:Econova.ViewModels"
      Background="White">

    <Page.Resources>
        <!-- 👇 Converter para bool → Visibility -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <SolidColorBrush x:Key="AccentBrush"   Color="#2563EB"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#000000"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#6B7280"/>
        <SolidColorBrush x:Key="BorderColor"   Color="#E5E7EB"/>
        <SolidColorBrush x:Key="InputBg"       Color="#F9FAFB"/>

        <Style x:Key="ViewButtonStyle" TargetType="Button">
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#D1D5DB"/>
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="#000000"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EEF2FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ViewButtonActiveStyle" TargetType="Button"
               BasedOn="{StaticResource ViewButtonStyle}">
            <Setter Property="Background"  Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="Foreground"  Value="White"/>
        </Style>

        <Style x:Key="NavCalButtonStyle" TargetType="Button">
            <Setter Property="Width"           Value="32"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontFamily"      Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Foreground"      Value="#000000"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EEF2FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnEditarStyle" TargetType="Button"
               BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background"  Value="#FFFBEB"/>
            <Setter Property="BorderBrush" Value="#FDE68A"/>
            <Setter Property="Foreground"  Value="#92400E"/>
        </Style>

        <Style x:Key="BtnCancelarStyle" TargetType="Button"
               BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background"  Value="#FEF2F2"/>
            <Setter Property="BorderBrush" Value="#FECACA"/>
            <Setter Property="Foreground"  Value="#DC2626"/>
        </Style>

        <Style x:Key="ColHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontFamily"        Value="Segoe UI"/>
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="FontWeight"        Value="SemiBold"/>
            <Setter Property="Foreground"        Value="#6B7280"/>
            <Setter Property="Padding"           Value="12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CellStyle" TargetType="TextBlock">
            <Setter Property="FontFamily"        Value="Segoe UI"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="Foreground"        Value="#000000"/>
            <Setter Property="Padding"           Value="12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming"      Value="CharacterEllipsis"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══════ ENCABEZADO ══════ -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,0,1"
                Padding="28,16,28,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="40" Height="40" CornerRadius="10"
                            Background="#EFF6FF" Margin="0,0,14,0">
                        <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="20" Foreground="#2563EB"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding FechaDiaTexto}"
                                   FontFamily="Segoe UI" FontSize="18"
                                   FontWeight="Bold" Foreground="#000000"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="{Binding DiaSemanaTexto}"
                                       FontFamily="Segoe UI" FontSize="12"
                                       FontWeight="SemiBold" Foreground="#6B7280"/>
                            <TextBlock Text=" • " Foreground="#D1D5DB"/>
                            <TextBlock Text="{Binding SubtituloTexto}"
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="#6B7280"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Botones de vista -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource ViewButtonActiveStyle}"
                            Margin="0,0,8,0"
                            Command="{Binding VerCalendarioCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="13" Margin="0,0,6,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Hoy" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ViewButtonStyle}"
                            Command="{Binding VerTodasCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="13" Margin="0,0,6,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Todas las reservas" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════ CONTENIDO ══════ -->
        <Grid Grid.Row="1">

            <!-- ── VISTA CALENDARIO ── -->
            <Grid x:Name="PanelCalendario"
                  Visibility="{Binding MostrarCalendario, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Barra de navegación del día -->
                <Border Grid.Row="0" Background="#F9FAFB"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="0,0,0,1"
                        Padding="28,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Style="{StaticResource NavCalButtonStyle}"
                                Content="&#xE76B;"
                                ToolTip="Día anterior"
                                Command="{Binding DiaAnteriorCommand}"/>

                        <StackPanel Grid.Column="1" HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding FechaDiaTexto}"
                                       FontFamily="Segoe UI" FontSize="15"
                                       FontWeight="Bold" Foreground="#000000"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding DiaSemanaTexto}"
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="#6B7280"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <Button Grid.Column="2"
                                Style="{StaticResource NavCalButtonStyle}"
                                Content="&#xE76C;"
                                ToolTip="Día siguiente"
                                Command="{Binding DiaSiguienteCommand}"/>
                    </Grid>
                </Border>

                <!-- Área de horas + eventos -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Labels de hora -->
                        <StackPanel Grid.Column="0">
                            <Border Height="56" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                                <TextBlock Text="06:00" FontFamily="Segoe UI" FontSize="11" Foreground="#9CA3AF" Margin="8,6,0,0" VerticalAlignment="Top"/>
                            </Border>
                            <Border Height="56" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                                <TextBlock Text="07:00" FontFamily="Segoe UI" FontSize="11" Foreground="#9CA3AF" Margin="8,6,0,0" VerticalAlignment="Top"/>
                            </Border>
                            <Border Height="56" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                                <TextBlock Text="08:00" FontFamily="Segoe UI" FontSize="11" Foreground="#9CA3AF" Margin="8,6,0,0" VerticalAlignment="Top"/>
                            </Border>
                            <Border Height="56" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                                <TextBlock Text="09:00" FontFamily="Segoe UI" FontSize="11" Foreground="#9CA3AF" Margin="8,6,0,0" VerticalAlignment="Top"/>
                            </Border>
                            <Border Height="56" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                                <TextBlock Text="10:00" FontFamily="Segoe UI" FontSize="11" Foreground="#9CA3AF" Margin="8,6,0,0" VerticalAlignment="Top"/>
                            </Border>
                            <Border Height="56" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                                <TextBlock Text="11:00" FontFamily="Segoe UI" FontSize="11" Foreground="#9CA3AF" Margin="8,6,0,0" VerticalAlignment="Top"/>
                            </Border>
                            <Border Height="56" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                                <TextBlock Text="12:00" FontFamily="Segoe UI" FontSize="11" Foreground="#9CA3AF" Margin="8,6,0,0" VerticalAlignment="Top"/>
                            </Border>
                            <Border Height="56" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                                <TextBlock Text="13:00" FontFamily="Segoe UI" FontSize="11" Foreground="#9CA3AF" Margin="8,6,0,0" VerticalAlignment="Top"/>
                            </Border>
                            <Border Height="56" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                                <TextBlock Text="14:00" FontFamily="Segoe UI" FontSize="11" Foreground="#9CA3AF" Margin="8,6,0,0" VerticalAlignment="Top"/>
                            </Border>
                            <Border Height="56" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                                <TextBlock Text="15:00" FontFamily="Segoe UI" FontSize="11" Foreground="#9CA3AF" Margin="8,6,0,0" VerticalAlignment="Top"/>
                            </Border>
                            <Border Height="56" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                                <TextBlock Text="16:00" FontFamily="Segoe UI" FontSize="11" Foreground="#9CA3AF" Margin="8,6,0,0" VerticalAlignment="Top"/>
                            </Border>
                            <Border Height="56" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                                <TextBlock Text="17:00" FontFamily="Segoe UI" FontSize="11" Foreground="#9CA3AF" Margin="8,6,0,0" VerticalAlignment="Top"/>
                            </Border>
                            <Border Height="56" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                                <TextBlock Text="18:00" FontFamily="Segoe UI" FontSize="11" Foreground="#9CA3AF" Margin="8,6,0,0" VerticalAlignment="Top"/>
                            </Border>
                            <Border Height="56" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                                <TextBlock Text="19:00" FontFamily="Segoe UI" FontSize="11" Foreground="#9CA3AF" Margin="8,6,0,0" VerticalAlignment="Top"/>
                            </Border>
                            <Border Height="56" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                                <TextBlock Text="20:00" FontFamily="Segoe UI" FontSize="11" Foreground="#9CA3AF" Margin="8,6,0,0" VerticalAlignment="Top"/>
                            </Border>
                            <Border Height="56" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                                <TextBlock Text="21:00" FontFamily="Segoe UI" FontSize="11" Foreground="#9CA3AF" Margin="8,6,0,0" VerticalAlignment="Top"/>
                            </Border>
                        </StackPanel>

                        <!-- Área de eventos -->
                        <Border Grid.Column="1"
                                BorderBrush="#F3F4F6"
                                BorderThickness="1,0,0,0">
                            <Grid>
                                <StackPanel>
                                    <Border Height="56" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Background="Transparent"/>
                                    <Border Height="56" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Background="Transparent"/>
                                    <Border Height="56" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Background="Transparent"/>
                                    <Border Height="56" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Background="Transparent"/>
                                    <Border Height="56" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Background="Transparent"/>
                                    <Border Height="56" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Background="Transparent"/>
                                    <Border Height="56" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Background="Transparent"/>
                                    <Border Height="56" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Background="Transparent"/>
                                    <Border Height="56" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Background="Transparent"/>
                                    <Border Height="56" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Background="Transparent"/>
                                    <Border Height="56" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Background="Transparent"/>
                                    <Border Height="56" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Background="Transparent"/>
                                    <Border Height="56" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Background="Transparent"/>
                                    <Border Height="56" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Background="Transparent"/>
                                    <Border Height="56" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Background="Transparent"/>
                                    <Border Height="56" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Background="Transparent"/>
                                </StackPanel>

                                <Canvas x:Name="CanvasEventos" Height="896"/>
                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- ── VISTA TODAS LAS RESERVAS ── -->
            <Grid x:Name="PanelTodasReservas"
                  Visibility="{Binding MostrarTodas, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Barra de búsqueda -->
                <Border Grid.Row="0" Background="#F9FAFB"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="0,0,0,1"
                        Padding="28,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Background="White" BorderBrush="#9CA3AF"
                                BorderThickness="1" CornerRadius="8"
                                Width="340" HorizontalAlignment="Left">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="13" Foreground="#9CA3AF"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         FontFamily="Segoe UI" FontSize="13"
                                         Foreground="#000000"
                                         Height="36"
                                         VerticalContentAlignment="Center"/>
                            </Grid>
                        </Border>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding ContadorTexto}"
                                   FontFamily="Segoe UI" FontSize="13"
                                   Foreground="#6B7280"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Tabla -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="28,16,28,24">

                        <!-- Encabezado de tabla -->
                        <Border Background="#F9FAFB"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="1" CornerRadius="8,8,0,0"
                                Height="40">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="190"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="#"
                                           Style="{StaticResource ColHeaderStyle}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Sala"
                                           Style="{StaticResource ColHeaderStyle}"/>
                                <TextBlock Grid.Column="2" Text="Cliente"
                                           Style="{StaticResource ColHeaderStyle}"/>
                                <TextBlock Grid.Column="3" Text="Cédula"
                                           Style="{StaticResource ColHeaderStyle}"/>
                                <TextBlock Grid.Column="4" Text="Entrada"
                                           Style="{StaticResource ColHeaderStyle}"/>
                                <TextBlock Grid.Column="5" Text="Acciones"
                                           Style="{StaticResource ColHeaderStyle}"
                                           HorizontalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Filas -->
                        <ItemsControl ItemsSource="{Binding ReservasFiltradas}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource BorderColor}"
                                            BorderThickness="1,0,1,1"
                                            Height="52" Background="White">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F9FAFB"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="190"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="{Binding Numero}"
                                                       Style="{StaticResource CellStyle}"
                                                       Foreground="#9CA3AF"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Sala}"
                                                       Style="{StaticResource CellStyle}"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Cliente}"
                                                       Style="{StaticResource CellStyle}"/>
                                            <TextBlock Grid.Column="3" Text="{Binding Cedula}"
                                                       Style="{StaticResource CellStyle}"
                                                       Foreground="#6B7280"/>
                                            <StackPanel Grid.Column="4"
                                                        VerticalAlignment="Center"
                                                        Margin="12,0">
                                                <TextBlock Text="{Binding FechaEntrada}"
                                                           FontFamily="Segoe UI" FontSize="12"
                                                           Foreground="#000000"/>
                                                <TextBlock Text="{Binding HoraEntrada}"
                                                           FontFamily="Segoe UI" FontSize="11"
                                                           Foreground="#6B7280"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="5"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                <Button Style="{StaticResource BtnEditarStyle}"
                                                        Margin="0,0,8,0"
                                                        Command="{Binding DataContext.EditarCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding Id}">
                                                    <StackPanel Orientation="Horizontal" Margin="4,0">
                                                        <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="12" Margin="0,0,6,0"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Text="Editar" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource BtnCancelarStyle}"
                                                        Command="{Binding DataContext.CancelarCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding Id}">
                                                    <StackPanel Orientation="Horizontal" Margin="4,0">
                                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="12" Margin="0,0,6,0"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Text="Cancelar" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Pie de tabla -->
                        <Border Background="#F9FAFB"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="1,0,1,1"
                                CornerRadius="0,0,8,8"
                                Height="12"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

        </Grid>
    </Grid>
</Page>