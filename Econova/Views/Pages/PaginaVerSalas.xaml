<Page x:Class="Econova.Views.Pages.PaginaVerSalas"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:Econova.ViewModels"
      Background="#F3F4F6">

    <Page.Resources>
        <SolidColorBrush x:Key="AccentBrush"  Color="#2563EB"/>
        <SolidColorBrush x:Key="BorderColor"  Color="#E5E7EB"/>

        <Style x:Key="ColHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontFamily"        Value="Segoe UI"/>
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="FontWeight"        Value="SemiBold"/>
            <Setter Property="Foreground"        Value="#6B7280"/>
            <Setter Property="Padding"           Value="12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CellStyle" TargetType="TextBlock">
            <Setter Property="FontFamily"        Value="Segoe UI"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="Foreground"        Value="#000000"/>
            <Setter Property="Padding"           Value="12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming"      Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnEliminarStyle" TargetType="Button"
               BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background"  Value="#FEF2F2"/>
            <Setter Property="BorderBrush" Value="#FECACA"/>
            <Setter Property="Foreground"  Value="#DC2626"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══════ ENCABEZADO ══════ -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,0,1"
                Padding="28,16,28,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="40" Height="40" CornerRadius="10"
                            Background="#F0FDF4" Margin="0,0,14,0">
                        <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="20" Foreground="#059669"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Salas"
                                   FontFamily="Segoe UI" FontSize="18"
                                   FontWeight="Bold" Foreground="#111827"/>
                        <TextBlock Text="{Binding SubtituloTexto}"
                                   FontFamily="Segoe UI" FontSize="12"
                                   Foreground="#6B7280"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Agregar sala"
                        Background="#2563EB" Foreground="White"
                        FontWeight="SemiBold"
                        Padding="16,0" Height="38"
                        Click="BtnAgregarSala_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                    CornerRadius="8">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <ContentPresenter/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#1D4ED8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ══════ BUSCADOR Y CONTADOR ══════ -->
        <Border Grid.Row="1" Padding="28,20,28,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1" CornerRadius="8" Height="38">
                    <Grid>
                        <TextBox Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" BorderThickness="0"
                                 VerticalContentAlignment="Center" Padding="12,0"
                                 FontFamily="Segoe UI" FontSize="13"/>
                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   Margin="0,0,12,0" Foreground="#9CA3AF"/>
                    </Grid>
                </Border>

                <TextBlock Grid.Column="2" Text="{Binding ContadorTexto}"
                           FontFamily="Segoe UI" FontSize="13"
                           Foreground="#6B7280" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ══════ TABLA DE SALAS ══════ -->
        <Border Grid.Row="2" Margin="28,20,28,28"
                Background="White" CornerRadius="12"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Cabeceras -->
                <Border Grid.Row="0" Background="#F9FAFB" CornerRadius="12,12,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="#" Style="{StaticResource ColHeaderStyle}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text=""  Style="{StaticResource ColHeaderStyle}"/>
                        <TextBlock Grid.Column="2" Text="NOMBRE DE LA SALA" Style="{StaticResource ColHeaderStyle}"/>
                        <TextBlock Grid.Column="3" Text="CAPACIDAD" Style="{StaticResource ColHeaderStyle}"/>
                        <TextBlock Grid.Column="4" Text="ACCIONES" Style="{StaticResource ColHeaderStyle}" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Lista de Salas -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding SalasFiltradas}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
                                    <Grid Height="54">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Numero}" Style="{StaticResource CellStyle}" HorizontalAlignment="Center" Foreground="#6B7280"/>

                                        <Border Grid.Column="1" Width="34" Height="34" CornerRadius="17" Background="#F3F4F6" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding Inicial}" FontFamily="Segoe UI" FontSize="13" FontWeight="Bold" Foreground="#4B5563" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <TextBlock Grid.Column="2" Text="{Binding Nombre}" Style="{StaticResource CellStyle}" FontWeight="SemiBold"/>

                                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                                            <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#6B7280" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Capacidad}" Style="{StaticResource CellStyle}" Padding="0"/>
                                            <TextBlock Text=" personas" Style="{StaticResource CellStyle}" Foreground="#6B7280" Padding="4,0"/>
                                        </StackPanel>

                                        <Button Grid.Column="4" Content="Eliminar"
                                                Style="{StaticResource BtnEliminarStyle}"
                                                Command="{Binding DataContext.EliminarCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding Id}"
                                                HorizontalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
