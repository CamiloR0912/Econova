<Page x:Class="Econova.Views.Pages.PaginaInicio"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="White">

    <Page.Resources>
        <SolidColorBrush x:Key="TextPrimary"   Color="#111827"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#6B7280"/>
        <SolidColorBrush x:Key="CardBg"        Color="#FFFFFF"/>
        <SolidColorBrush x:Key="CardBorder"    Color="#E5E7EB"/>

        <Style x:Key="QuickCardStyle" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="Padding"         Value="18,16"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,24,28,24">

            <!-- Imagen hero -->
            <Border CornerRadius="12,12,0,0" Height="250" ClipToBounds="True">
                <Image Source="/Assets/logotipo-econova.jpg"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </Border>

            <!-- Banner bienvenida -->
            <Border CornerRadius="0,0,12,12" Height="72" Margin="0,0,0,24"
                    ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1D4ED8" Offset="0"/>
                        <GradientStop Color="#7C3AED" Offset="0.6"/>
                        <GradientStop Color="#A855F7" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="28,0,28,0">
                    <TextBlock Text="Bienvenido a Econova"
                               FontFamily="Segoe UI" FontSize="20" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Acceso rápido -->
            <TextBlock Text="Acceso rápido"
                       FontFamily="Segoe UI" FontSize="15" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimary}"
                       Margin="0,0,0,12"/>

            <UniformGrid Columns="3">

                <!-- Card Reservas -->
                <Border Style="{StaticResource QuickCardStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <Border Width="40" Height="40" CornerRadius="8"
                                HorizontalAlignment="Left" Margin="0,0,0,12">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#2563EB" Offset="0"/>
                                    <GradientStop Color="#60A5FA" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="18" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Reservas"
                                   FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="Gestiona las reservas activas."
                                   FontFamily="Segoe UI" FontSize="11"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Card Clientes -->
                <Border Style="{StaticResource QuickCardStyle}" Margin="5,0,5,0">
                    <StackPanel>
                        <Border Width="40" Height="40" CornerRadius="8"
                                HorizontalAlignment="Left" Margin="0,0,0,12">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#059669" Offset="0"/>
                                    <GradientStop Color="#34D399" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="18" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Clientes"
                                   FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="Consulta y administra clientes."
                                   FontFamily="Segoe UI" FontSize="11"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Card Salas -->
                <Border Style="{StaticResource QuickCardStyle}" Margin="10,0,0,0">
                    <StackPanel>
                        <Border Width="40" Height="40" CornerRadius="8"
                                HorizontalAlignment="Left" Margin="0,0,0,12">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#7C3AED" Offset="0"/>
                                    <GradientStop Color="#C084FC" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="18" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Salas"
                                   FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="Revisa disponibilidad de salas."
                                   FontFamily="Segoe UI" FontSize="11"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

        </StackPanel>
    </ScrollViewer>
</Page>