<Window x:Class="Econova.Views.Windows.VentanaEditarReserva"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Econova.ViewModels"
        Title="Editar reserva"
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Border CornerRadius="12" Background="White"
            BorderBrush="#D1D5DB" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000" BlurRadius="24"
                              ShadowDepth="4" Opacity="0.12"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" CornerRadius="12,12,0,0"
                    Background="White"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="18,0,0,0">
                        <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" Foreground="#2563EB"
                                   Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Editar reserva"
                                   FontFamily="Segoe UI" FontSize="14"
                                   FontWeight="SemiBold" Foreground="#000000"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="1" Width="40" Height="40"
                            Margin="0,0,6,0" BorderThickness="0"
                            Background="Transparent" Cursor="Hand"
                            Command="{Binding CerrarCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="Transparent" CornerRadius="6">
                                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="11" Foreground="#6B7280"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#FEE2E2"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <Rectangle Grid.Row="0" Height="1"
                       VerticalAlignment="Bottom" Fill="#E5E7EB"/>

            <!-- Contenido -->
            <StackPanel Grid.Row="1" Margin="24,20,24,24">

                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="Sala" FontFamily="Segoe UI"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#000000" Margin="0,0,0,6"/>
                    <TextBox Height="38"
                             Text="{Binding Sala, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Segoe UI" FontSize="13"
                             Padding="10,0" VerticalContentAlignment="Center"
                             BorderBrush="#D1D5DB" BorderThickness="1"/>
                </StackPanel>

                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Cliente" FontFamily="Segoe UI"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#000000" Margin="0,0,0,6"/>
                        <TextBox Height="38"
                                 Text="{Binding Cliente, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Segoe UI" FontSize="13"
                                 Padding="10,0" VerticalContentAlignment="Center"
                                 BorderBrush="#D1D5DB" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Cédula" FontFamily="Segoe UI"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#000000" Margin="0,0,0,6"/>
                        <TextBox Height="38"
                                 Text="{Binding Cedula}"
                                 FontFamily="Segoe UI" FontSize="13"
                                 Padding="10,0" VerticalContentAlignment="Center"
                                 BorderBrush="#D1D5DB" BorderThickness="1"
                                 IsReadOnly="True" Background="#F9FAFB"
                                 Foreground="#6B7280"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Fecha entrada" FontFamily="Segoe UI"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#000000" Margin="0,0,0,6"/>
                        <TextBox Height="38"
                                 Text="{Binding FechaEntrada, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Segoe UI" FontSize="13"
                                 Padding="10,0" VerticalContentAlignment="Center"
                                 BorderBrush="#D1D5DB" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Hora entrada" FontFamily="Segoe UI"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#000000" Margin="0,0,0,6"/>
                        <TextBox Height="38"
                                 Text="{Binding HoraEntrada, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Segoe UI" FontSize="13"
                                 Padding="10,0" VerticalContentAlignment="Center"
                                 BorderBrush="#D1D5DB" BorderThickness="1"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Fecha salida" FontFamily="Segoe UI"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#000000" Margin="0,0,0,6"/>
                        <TextBox Height="38"
                                 Text="{Binding FechaSalida, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Segoe UI" FontSize="13"
                                 Padding="10,0" VerticalContentAlignment="Center"
                                 BorderBrush="#D1D5DB" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Hora salida" FontFamily="Segoe UI"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#000000" Margin="0,0,0,6"/>
                        <TextBox Height="38"
                                 Text="{Binding HoraSalida, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Segoe UI" FontSize="13"
                                 Padding="10,0" VerticalContentAlignment="Center"
                                 BorderBrush="#D1D5DB" BorderThickness="1"/>
                    </StackPanel>
                </Grid>

                <Rectangle Height="1" Fill="#E5E7EB" Margin="0,0,0,20"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Cancelar"
                            Height="40" FontFamily="Segoe UI"
                            FontSize="13" FontWeight="SemiBold"
                            Background="White" Foreground="#6B7280"
                            BorderBrush="#D1D5DB" BorderThickness="1"
                            Cursor="Hand" Command="{Binding CerrarCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#F3F4F6"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Grid.Column="2" Content="Guardar cambios"
                            Height="40" FontFamily="Segoe UI"
                            FontSize="13" FontWeight="SemiBold"
                            Background="#2563EB" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Command="{Binding GuardarCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#1D4ED8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

            </StackPanel>
        </Grid>
    </Border>
</Window>
