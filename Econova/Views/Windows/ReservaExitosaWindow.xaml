<Window x:Class="Econova.Views.Windows.ReservaExitosaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="" Height="Auto" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="Height">

    <Window.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height"          Value="42"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="12" CornerRadius="16" Background="White">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="32"
                              ShadowDepth="4" Opacity="0.13"/>
        </Border.Effect>

        <StackPanel>

            <!-- Franja verde de éxito -->
            <Border CornerRadius="16,16,0,0" Height="6">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#059669" Offset="0"/>
                        <GradientStop Color="#34D399" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <StackPanel Margin="32,28,32,28">

                <!-- Ícono de éxito -->
                <Border Width="72" Height="72" CornerRadius="36"
                        Background="#F0FDF4" HorizontalAlignment="Center"
                        Margin="0,0,0,20">
                    <TextBlock Text="&#xE930;"
                               FontFamily="Segoe MDL2 Assets" FontSize="32"
                               Foreground="#059669"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Título -->
                <TextBlock Text="¡Reserva confirmada!"
                           FontFamily="Segoe UI" FontSize="18" FontWeight="Bold"
                           Foreground="#111827"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>

                <!-- Subtítulo -->
                <TextBlock Text="La reserva ha sido registrada exitosamente en el sistema."
                           FontFamily="Segoe UI" FontSize="13"
                           Foreground="#6B7280"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,24"/>

                <!-- Tarjeta resumen -->
                <Border Background="#F9FAFB" BorderBrush="#E5E7EB"
                        BorderThickness="1" CornerRadius="10"
                        Padding="16,14" Margin="0,0,0,28">
                    <StackPanel>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE8EF;"
                                       FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="#9CA3AF" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtResumenSala" Grid.Column="1"
                                       FontFamily="Segoe UI" FontSize="12"
                                       FontWeight="SemiBold" Foreground="#374151"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE787;"
                                       FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="#9CA3AF" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtResumenFechas" Grid.Column="1"
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="#374151" TextWrapping="Wrap"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE716;"
                                       FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="#9CA3AF" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtResumenCliente" Grid.Column="1"
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="#374151"/>
                        </Grid>

                    </StackPanel>
                </Border>

                <!-- Botón volver al inicio -->
                <Button Style="{StaticResource ActionButton}"
                        Background="#2563EB" Foreground="White"
                        Content="Volver al inicio"
                        Click="BtnVolver_Click"/>

            </StackPanel>
        </StackPanel>
    </Border>
</Window>