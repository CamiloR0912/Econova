<Window x:Class="Econova.Views.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Econova.ViewModels"
        Title="Econova"
        Icon="/Assets/icono.ico"
        Width="1100" Height="720"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush"      Color="#2563EB"/>
        <SolidColorBrush x:Key="AccentLightBrush" Color="#3B82F6"/>
        <SolidColorBrush x:Key="SidebarBg"        Color="#F3F4F6"/>
        <SolidColorBrush x:Key="ContentBg"        Color="#FFFFFF"/>
        <SolidColorBrush x:Key="CardBg"           Color="#FFFFFF"/>
        <SolidColorBrush x:Key="CardBorder"       Color="#E5E7EB"/>
        <SolidColorBrush x:Key="TextPrimary"      Color="#111827"/>
        <SolidColorBrush x:Key="TextSecondary"    Color="#6B7280"/>
        <SolidColorBrush x:Key="NavHover"         Color="#E0E7FF"/>
        <SolidColorBrush x:Key="NavActive"        Color="#EEF2FF"/>
        <SolidColorBrush x:Key="TitleBarBg"       Color="#FFFFFF"/>
        <SolidColorBrush x:Key="WindowBorder"     Color="#D1D5DB"/>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="Foreground"                 Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize"                   Value="13"/>
            <Setter Property="FontFamily"                 Value="Segoe UI"/>
            <Setter Property="Height"                     Value="38"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"                    Value="12,0,12,0"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{StaticResource NavHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Background" Value="{StaticResource NavActive}"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="NavButtonManualStyle" TargetType="Button">
            <Setter Property="Background"                 Value="#DBEAFE"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="Foreground"                 Value="#1D4ED8"/>
            <Setter Property="FontSize"                   Value="13"/>
            <Setter Property="FontFamily"                 Value="Segoe UI"/>
            <Setter Property="FontWeight"                 Value="SemiBold"/>
            <Setter Property="Height"                     Value="38"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"                    Value="12,0,12,0"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#BFDBFE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonSalirStyle" TargetType="Button">
            <Setter Property="Background"                 Value="#FEE2E2"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="Foreground"                 Value="#DC2626"/>
            <Setter Property="FontSize"                   Value="13"/>
            <Setter Property="FontFamily"                 Value="Segoe UI"/>
            <Setter Property="FontWeight"                 Value="SemiBold"/>
            <Setter Property="Height"                     Value="38"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"                    Value="12,0,12,0"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FECACA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width"           Value="46"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontFamily"      Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EF4444"/>
                    <Setter Property="Foreground"  Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="Padding"         Value="20"/>
        </Style>

        <Style x:Key="QuickCardStyle" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="Padding"         Value="18,16"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="10"
            BorderBrush="{StaticResource WindowBorder}"
            BorderThickness="1"
            Background="{StaticResource ContentBg}">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="24" ShadowDepth="4" Opacity="0.12"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Border Grid.Row="0" Grid.ColumnSpan="2"
                    Background="{StaticResource TitleBarBg}"
                    CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="14,0,0,0">
                        <Image Source="/Assets/icono.ico"
                               Width="24" Height="24" Margin="0,0,8,0"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="Econova"
                                   FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Style="{StaticResource TitleBarButtonStyle}"
                                Content="&#xE921;" ToolTip="Minimizar"
                                Click="BtnMinimize_Click"/>
                        <Button Style="{StaticResource TitleBarButtonStyle}"
                                Content="&#xE922;" ToolTip="Maximizar"
                                Click="BtnMaximize_Click"/>
                        <Button Style="{StaticResource CloseButtonStyle}"
                                Content="&#xE8BB;" ToolTip="Cerrar"
                                Click="BtnClose_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Rectangle Grid.Row="0" Grid.ColumnSpan="2"
                       Height="1" VerticalAlignment="Bottom" Fill="#E5E7EB"/>

            <!-- SIDEBAR -->
            <Border Grid.Row="1" Grid.Column="0"
                    Background="{StaticResource SidebarBg}"
                    CornerRadius="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="8,12,8,0">

                        <!-- Inicio -->
                        <Button x:Name="BtnInicio"
                            Style="{StaticResource NavButtonActiveStyle}"
                            Margin="0,1" Click="BtnInicio_Click">       
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets"
                                    FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Inicio" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Reservas -->
                        <StackPanel Margin="0,1">
                            <Button x:Name="BtnReservas"
            Style="{StaticResource NavButtonStyle}"
            Click="BtnReservas_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets"
                       FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Reservas" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock x:Name="ArrowReservas" Text="&#xE970;"
                       FontFamily="Segoe MDL2 Assets"
                       FontSize="10" VerticalAlignment="Center"
                       Foreground="#6B7280"/>
                                </StackPanel>
                            </Button>
                            <StackPanel x:Name="SubMenuReservas" Visibility="Collapsed" Margin="22,0,0,0">
                                <Button x:Name="BtnCrearReserva"
                Style="{StaticResource NavButtonStyle}" Height="34"
                Click="BtnCrearReserva_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets"
                           FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Crear reserva" VerticalAlignment="Center" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="BtnVerReservas"
                Style="{StaticResource NavButtonStyle}" Height="34"
                Click="BtnVerReservas_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets"
                           FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Ver reservas" VerticalAlignment="Center" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <!-- Clientes -->
                        <StackPanel Margin="0,1">
                            <Button x:Name="BtnClientes"
            Style="{StaticResource NavButtonStyle}"
            Click="BtnClientes_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets"
                       FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Clientes" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock x:Name="ArrowClientes" Text="&#xE970;"
                       FontFamily="Segoe MDL2 Assets"
                       FontSize="10" VerticalAlignment="Center"
                       Foreground="#6B7280"/>
                                </StackPanel>
                            </Button>
                            <StackPanel x:Name="SubMenuClientes" Visibility="Collapsed" Margin="22,0,0,0">
                                <Button x:Name="BtnCrearCliente"
                Style="{StaticResource NavButtonStyle}" Height="34"
                Click="BtnCrearCliente_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets"
                           FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Crear cliente" VerticalAlignment="Center" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="BtnVerClientes"
                Style="{StaticResource NavButtonStyle}" Height="34"
                Click="BtnVerClientes_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets"
                           FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Ver clientes" VerticalAlignment="Center" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <!-- Salas -->
                        <Button x:Name="BtnSalas"
        Style="{StaticResource NavButtonStyle}" Margin="0,1"
        Click="BtnSalas_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets"
                   FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Salas" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>

                    <!-- Botones inferiores -->
                    <StackPanel Grid.Row="1" Margin="8,0,8,12">
                        <Button Style="{StaticResource NavButtonManualStyle}"
                                Margin="0,0,0,6"
                                Click="BtnManual_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8A9;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Manual de usuario" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavButtonSalirStyle}"
                                Click="BtnSalir_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xF3B1;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Salir" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Rectangle Grid.Row="1" Grid.Column="0"
                       Width="1" HorizontalAlignment="Right" Fill="#E5E7EB"/>

            <!-- CONTENIDO PRINCIPAL -->
            <Frame x:Name="FrameContenido"
                   Grid.Row="1" Grid.ColumnSpan="2"
                   Margin="219,0,0,0"
                   NavigationUIVisibility="Hidden"/>

        </Grid>
    </Border>
</Window>