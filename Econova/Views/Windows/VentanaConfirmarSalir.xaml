<Window x:Class="Econova.Views.Windows.VentanaConfirmarSalir"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="420" Height="220"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Border CornerRadius="12"
            BorderBrush="#D1D5DB"
            BorderThickness="1"
            Background="White">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="24"
                              ShadowDepth="4" Opacity="0.12"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Encabezado -->
            <Border Grid.Row="0"
                    CornerRadius="12,12,0,0"
                    Background="#FEF2F2"
                    Padding="20,16">
                <StackPanel Orientation="Horizontal">
                    <Border Width="36" Height="36" CornerRadius="18"
                            Background="#FEE2E2" Margin="0,0,12,0">
                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="16" Foreground="#DC2626"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="¿Cerrar Econova?"
                                   FontFamily="Segoe UI" FontSize="15"
                                   FontWeight="Bold" Foreground="#111827"/>
                        <TextBlock Text="Esta acción cerrará la aplicación."
                                   FontFamily="Segoe UI" FontSize="12"
                                   Foreground="#6B7280" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Mensaje -->
            <Border Grid.Row="1" Padding="20,16">
                <TextBlock Text="Toda la información no guardada se perderá permanentemente. ¿Estás seguro de que deseas salir?"
                           FontFamily="Segoe UI" FontSize="13"
                           Foreground="#374151"
                           TextWrapping="Wrap"
                           LineHeight="20"/>
            </Border>

            <!-- Botones -->
            <Border Grid.Row="2"
                    BorderBrush="#E5E7EB"
                    BorderThickness="0,1,0,0"
                    Padding="20,14">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <!-- Cancelar -->
                    <Button x:Name="BtnCancelar"
                            Content="Cancelar"
                            Width="100" Height="36"
                            Margin="0,0,10,0"
                            FontFamily="Segoe UI" FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="#374151"
                            Cursor="Hand"
                            Click="BtnCancelar_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd"
                                        Background="White"
                                        BorderBrush="#D1D5DB"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#F9FAFB"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#F3F4F6"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Confirmar salir -->
                    <Button x:Name="BtnConfirmar"
                            Content="Sí, cerrar"
                            Width="110" Height="36"
                            FontFamily="Segoe UI" FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Cursor="Hand"
                            Click="BtnConfirmar_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd"
                                        Background="#DC2626"
                                        BorderThickness="0"
                                        CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#B91C1C"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#991B1B"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>