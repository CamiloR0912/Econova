<Window x:Class="Econova.Views.Windows.ConfirmacionEliminarClienteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="" Height="Auto" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="Height">

    <Window.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height"          Value="42"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="12" CornerRadius="16" Background="White">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="32"
                              ShadowDepth="4" Opacity="0.13"/>
        </Border.Effect>

        <StackPanel>

            <!-- Franja roja superior -->
            <Border CornerRadius="16,16,0,0" Height="6">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#DC2626" Offset="0"/>
                        <GradientStop Color="#F87171" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <StackPanel Margin="32,28,32,28">

                <!-- Ícono -->
                <Border Width="64" Height="64" CornerRadius="32"
                        Background="#FEF2F2" HorizontalAlignment="Center"
                        Margin="0,0,0,18">
                    <TextBlock Text="&#xE74D;"
                               FontFamily="Segoe MDL2 Assets" FontSize="28"
                               Foreground="#DC2626"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Título -->
                <TextBlock Text="Eliminar cliente"
                           FontFamily="Segoe UI" FontSize="18" FontWeight="Bold"
                           Foreground="#111827"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>

                <!-- Advertencia -->
                <TextBlock Text="Esta acción no se puede deshacer."
                           FontFamily="Segoe UI" FontSize="13"
                           Foreground="#DC2626"
                           HorizontalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>

                <TextBlock Text="¿Estás seguro de que deseas eliminar este cliente?"
                           FontFamily="Segoe UI" FontSize="13"
                           Foreground="#6B7280"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,24"/>

                <!-- Tarjeta datos del cliente -->
                <Border Background="#FEF2F2" BorderBrush="#FECACA"
                        BorderThickness="1" CornerRadius="10"
                        Padding="16,14" Margin="0,0,0,28">
                    <StackPanel>

                        <!-- Nombre -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE716;"
                                       FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="#F87171" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Nombre"
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="#F87171" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtNombre" Grid.Column="2"
                                       FontFamily="Segoe UI" FontSize="12"
                                       FontWeight="SemiBold" Foreground="#991B1B"
                                       TextWrapping="Wrap"/>
                        </Grid>

                        <!-- Cédula -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE8EC;"
                                       FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="#F87171" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Cédula"
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="#F87171" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtCedula" Grid.Column="2"
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="#991B1B"/>
                        </Grid>

                        <!-- Email -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE715;"
                                       FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="#F87171" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Email"
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="#F87171" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtEmail" Grid.Column="2"
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="#991B1B" TextWrapping="Wrap"/>
                        </Grid>

                    </StackPanel>
                </Border>

                <!-- Botones -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Style="{StaticResource ActionButton}"
                            Background="#F3F4F6" Foreground="#374151"
                            Content="Cancelar"
                            Click="BtnCancelar_Click"/>

                    <Button Grid.Column="2"
                            Style="{StaticResource ActionButton}"
                            Background="#DC2626" Foreground="White"
                            Content="Eliminar"
                            Click="BtnEliminar_Click"/>
                </Grid>

            </StackPanel>
        </StackPanel>
    </Border>
</Window>