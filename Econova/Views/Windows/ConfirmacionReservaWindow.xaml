<!-- Econova/Views/Dialogs/ConfirmacionReservaWindow.xaml -->
<Window x:Class="Econova.Views.Dialogs.ConfirmacionReservaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="" Height="Auto" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="Height">

    <Window.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height"          Value="42"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.72"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Sombra exterior -->
    <Border Margin="12" CornerRadius="16" Background="White">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="32"
                              ShadowDepth="4" Opacity="0.14"/>
        </Border.Effect>

        <StackPanel>
            <!-- Franja superior azul -->
            <Border Background="#2563EB" CornerRadius="16,16,0,0" Height="6"/>

            <!-- Cuerpo -->
            <StackPanel Margin="32,28,32,28">

                <!-- Ícono de éxito -->
                <Border Width="64" Height="64" CornerRadius="32"
                        Background="#EFF6FF"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,20">
                    <TextBlock Text="&#xE930;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="28"
                               Foreground="#2563EB"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Título -->
                <TextBlock x:Name="TxtTitulo"
                           Text="Confirmar reserva"
                           FontFamily="Segoe UI"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#111827"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <!-- Mensaje -->
                <TextBlock x:Name="TxtMensaje"
                           Text="¿Estás seguro de que deseas confirmar esta reserva?"
                           FontFamily="Segoe UI"
                           FontSize="13"
                           Foreground="#6B7280"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,28"/>

                <!-- Resumen de la reserva -->
                <Border x:Name="PanelResumen"
                        Background="#F9FAFB"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="16,14"
                        Margin="0,0,0,28">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE8EF;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="13" Foreground="#9CA3AF"
                                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtResumenSala"
                                       Grid.Column="1"
                                       Text="Sala 1 — Capacidad 10 personas"
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="#374151"
                                       FontWeight="SemiBold"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE787;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="13" Foreground="#9CA3AF"
                                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtResumenFechas"
                                       Grid.Column="1"
                                       Text="19/04/2026, 08:00 AM → 05:00 PM"
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="#374151"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE716;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="13" Foreground="#9CA3AF"
                                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtResumenCliente"
                                       Grid.Column="1"
                                       Text="Juan Pérez • 1234567890"
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="#374151"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Botones -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Cancelar -->
                    <Button Grid.Column="0"
                            Style="{StaticResource ActionButton}"
                            Background="#F3F4F6"
                            Foreground="#374151"
                            Content="Cancelar"
                            Click="BtnCancelar_Click"/>

                    <!-- Confirmar -->
                    <Button Grid.Column="2"
                            Style="{StaticResource ActionButton}"
                            Background="#2563EB"
                            Foreground="White"
                            Content="Confirmar"
                            Click="BtnConfirmar_Click"/>
                </Grid>

            </StackPanel>
        </StackPanel>
    </Border>
</Window>